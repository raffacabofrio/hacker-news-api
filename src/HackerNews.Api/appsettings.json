{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/",
    "RequestTimeoutSeconds": 10,
    "MaxConcurrentRequests": 10
  },
  "Cache": {
    "MemoryTtlSeconds": 5,
    "RedisTtlSeconds": 300,
    "RedisConnectionString": "redis:6379",
    "CacheKey": "beststories:v1"
  },
  "Refresh": {
    "IntervalSeconds": 60,
    "LockTtlSeconds": 45,
    "LockKey": "lock:beststories:refresh"
  }
}
